<Window x:Class="MedHelp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MedHelp — Вход" Height="500" Width="450"
        MinHeight="400" MinWidth="350"
        WindowStartupLocation="CenterScreen" 
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Вход в систему" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Border BorderBrush="Gray" BorderThickness="1" Padding="10" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Логин:" VerticalAlignment="Center" Padding="0" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtLogin" Grid.Column="1" BorderThickness="0" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="16" ToolTip="Введите логин (только буквы и цифры)">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding LoginCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Row="2" Margin="0,0,0,30">
            <Border BorderBrush="Gray" BorderThickness="1" Padding="10" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Пароль:" VerticalAlignment="Center" Padding="0" FontWeight="SemiBold"/>
                    <PasswordBox x:Name="pwdPassword" Grid.Column="1" BorderThickness="0" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="16" ToolTip="Введите пароль">
                        <PasswordBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding LoginCommand}"/>
                        </PasswordBox.InputBindings>
                    </PasswordBox>
                </Grid>
            </Border>
        </Grid>
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnLogin" Content="🚪 Войти" MinWidth="120" Height="40" Margin="0,0,15,0" Click="BtnLogin_Click" FontSize="14" Cursor="Hand" IsDefault="True" ToolTip="Выполнить вход (Enter)"/>
            <Button x:Name="btnCancel" Content="Отмена" MinWidth="100" Height="40" Click="BtnCancel_Click" FontSize="14" IsCancel="True" Cursor="Hand" ToolTip="Отмена (Esc)"/>
        </StackPanel>
    </Grid>
</Window>
