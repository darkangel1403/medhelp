<Window x:Class="MedHelp.Views.AdminDoctorsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Справочник врачей" Height="600" Width="850"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI">
    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CloseCommand}"/>
        <KeyBinding Key="F" Modifiers="Control" Command="{Binding FocusSearchCommand}"/>
    </Window.InputBindings>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Список врачей" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="5">
                <TextBox x:Name="txtSearch" FontSize="14" VerticalContentAlignment="Center" ToolTip="Поиск врача по ФИО (Ctrl+F)"/>
            </Border>
            <Button Grid.Column="1" Content="🔍 Найти" MinWidth="80" Margin="5,0,0,0" Click="BtnSearch_Click" ToolTip="Выполнить поиск"/>
        </Grid>
        <DataGrid Grid.Row="2" x:Name="dgDoctors" AutoGenerateColumns="False" IsReadOnly="True"
                  GridLinesVisibility="All" BorderBrush="Gray" RowHeight="30" FontSize="13"
                  SelectionChanged="DgDoctors_SelectionChanged" CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Специальность" Binding="{Binding Specialty}" Width="150"/>
                <DataGridTextColumn Header="Кабинет" Binding="{Binding CabinetNumber}" Width="80"/>
                <DataGridTextColumn Header="Стаж" Binding="{Binding ExperienceYears}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="btnAdd" Content="➕ Добавить" MinWidth="130" Height="40" Margin="5" Click="BtnAdd_Click" Cursor="Hand" FontSize="14" ToolTip="Добавить врача"/>
            <Button x:Name="btnEdit" Content="✏️ Изменить" MinWidth="130" Height="40" Margin="5" Click="BtnEdit_Click" IsEnabled="False" Cursor="Hand" FontSize="14" ToolTip="Изменить врача"/>
            <Button x:Name="btnAction" Content="🗑️ Удалить врача" MinWidth="130" Height="40" Margin="15,5" Click="BtnAction_Click" IsEnabled="False" Visibility="Collapsed" Cursor="Hand" FontSize="14" ToolTip="Удалить врача"/>
            <Button Content="Закрыть" MinWidth="130" Height="40" Margin="15,5" Click="BtnClose_Click" Cursor="Hand" FontSize="14" IsCancel="True" ToolTip="Закрыть (Esc)"/>
        </StackPanel>
    </Grid>
</Window>
