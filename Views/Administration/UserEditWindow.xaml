<Window x:Class="MedHelp.Views.UserEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование пользователя" Height="550" Width="550"
        MinHeight="450" MinWidth="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Данные пользователя" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,25"/>
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Border BorderBrush="Gray" BorderThickness="1" Padding="10" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Логин:" VerticalAlignment="Center" Padding="0" FontWeight="SemiBold"/>
                    <TextBox x:Name="tbLogin" Grid.Column="1" BorderThickness="0" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="16" ToolTip="Только латинские буквы и цифры"/>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Border BorderBrush="Gray" BorderThickness="1" Padding="10" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="ФИО:" VerticalAlignment="Center" Padding="0" FontWeight="SemiBold"/>
                    <TextBox x:Name="tbFullName" Grid.Column="1" BorderThickness="0" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="16" ToolTip="Только русские буквы"/>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Border BorderBrush="Gray" BorderThickness="1" Padding="10" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Адрес:" VerticalAlignment="Center" Padding="0" FontWeight="SemiBold"/>
                    <TextBox x:Name="tbAddress" Grid.Column="1" BorderThickness="0" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="16" ToolTip="Введите адрес"/>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Row="4" Margin="0,0,0,25">
            <Border BorderBrush="Gray" BorderThickness="1" Padding="10" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Телефон:" VerticalAlignment="Center" Padding="0" FontWeight="SemiBold"/>
                    <TextBox x:Name="tbPhone" Grid.Column="1" BorderThickness="0" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="16" ToolTip="Только + и цифры"/>
                </Grid>
            </Border>
        </Grid>
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="💾 Сохранить" MinWidth="140" Height="40" Margin="5" Click="BtnSave_Click" FontSize="16" Cursor="Hand" IsDefault="True" ToolTip="Сохранить (Enter)"/>
            <Button Content="❌ Отмена" MinWidth="120" Height="40" Margin="5" Click="BtnCancel_Click" FontSize="16" IsCancel="True" Cursor="Hand" ToolTip="Отмена (Esc)"/>
        </StackPanel>
    </Grid>
</Window>
