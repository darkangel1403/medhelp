<Window x:Class="MedHelp.Views.DoctorEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карточка врача" Height="550" Width="500"
        MinHeight="450" MinWidth="400"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="CanResizeWithGrip" 
        FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Данные врача" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="ФИО:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox x:Name="tbFullName" Grid.Column="1" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Специальность:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox x:Name="tbSpecialty" Grid.Column="1" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Кабинет:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox x:Name="tbCabinet" Grid.Column="1" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Row="4" Margin="0,0,0,15">
            <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Стаж (лет):" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBox x:Name="tbExp" Grid.Column="1" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Row="5" Margin="0,0,0,20">
            <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Label Content="Образование:" Grid.Row="0" FontWeight="SemiBold"/>
                    <TextBox x:Name="tbEdu" Grid.Row="1" Margin="0,5,0,0" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" MinHeight="80"/>
                </Grid>
            </Border>
        </Grid>
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="💾 Сохранить" MinWidth="120" Height="35" Margin="5" Click="BtnSave_Click" Cursor="Hand" IsDefault="True" ToolTip="Сохранить (Enter)"/>
            <Button Content="❌ Отмена" MinWidth="100" Height="35" Margin="5" Click="BtnCancel_Click" IsCancel="True" Cursor="Hand" ToolTip="Отмена (Esc)"/>
        </StackPanel>
    </Grid>
</Window>
