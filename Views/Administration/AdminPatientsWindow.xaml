<Window x:Class="MedHelp.Views.AdminPatientsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Справочник пациентов" Height="650" Width="900"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Список пациентов" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="5">
                <TextBox x:Name="txtSearch" FontSize="16" VerticalContentAlignment="Center" ToolTip="Поиск пациента по ФИО (Ctrl+F)"/>
            </Border>
            <Button Grid.Column="1" Content="🔍 Найти" MinWidth="100" Margin="5,0,0,0" Click="BtnSearch_Click" FontSize="14" ToolTip="Выполнить поиск"/>
        </Grid>
        <DataGrid Grid.Row="2" x:Name="dgUsers" AutoGenerateColumns="False" IsReadOnly="True"
                  GridLinesVisibility="All" BorderBrush="Gray" RowHeight="35" FontSize="14"
                  SelectionChanged="DgUsers_SelectionChanged" CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="150"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="80"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding PhoneNumber}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="btnAdd" Content="➕ Добавить" MinWidth="140" Height="40" Margin="5" Click="BtnAdd_Click" Cursor="Hand" FontSize="14" ToolTip="Добавить пациента"/>

            <Button x:Name="btnEdit" Content="✏️ Изменить" MinWidth="140" Height="40" Margin="5" Click="BtnEdit_Click" IsEnabled="False" Cursor="Hand" FontSize="14" ToolTip="Изменить пациента"/>

            <Button x:Name="btnAction" Content="🗑️ Удалить" MinWidth="150" Height="40" Margin="5" Click="BtnAction_Click" IsEnabled="False" Visibility="Collapsed" Cursor="Hand" FontSize="14" ToolTip="Удалить пациента"/>

            <Button Content="Закрыть" MinWidth="120" Height="40" Margin="5" Click="BtnClose_Click" Cursor="Hand" IsCancel="True" FontSize="14" ToolTip="Закрыть (Esc)"/>
        </StackPanel>
    </Grid>
</Window>
