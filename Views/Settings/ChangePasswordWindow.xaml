<Window x:Class="MedHelp.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изменение пароля" Height="450" Width="500"
        MinHeight="350" MinWidth="400"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="🔑 Смена пароля" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,25"/>
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Текущий пароль:" VerticalAlignment="Center" Padding="0" FontWeight="SemiBold"/>
                    <PasswordBox x:Name="pwdOldPassword" Grid.Column="1" BorderThickness="0" VerticalAlignment="Center" Margin="5,0,0,0" FontSize="14"/>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Новый пароль:" VerticalAlignment="Center" Padding="0" FontWeight="SemiBold"/>
                    <PasswordBox x:Name="pwdNewPassword" Grid.Column="1" BorderThickness="0" VerticalAlignment="Center" Margin="5,0,0,0" FontSize="14"/>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Row="3" Margin="0,0,0,25">
            <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Подтверждение:" VerticalAlignment="Center" Padding="0" FontWeight="SemiBold"/>
                    <PasswordBox x:Name="pwdConfirmPassword" Grid.Column="1" BorderThickness="0" VerticalAlignment="Center" Margin="5,0,0,0" FontSize="14"/>
                </Grid>
            </Border>
        </Grid>
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="💾 Сохранить" MinWidth="120" Height="35" Margin="5" Click="BtnSave_Click" FontSize="14" Cursor="Hand" IsDefault="True" ToolTip="Сохранить (Enter)"/>
            <Button Content="❌ Отмена" MinWidth="100" Height="35" Margin="5" Click="BtnCancel_Click" FontSize="14" IsCancel="True" Cursor="Hand" ToolTip="Отмена (Esc)"/>
        </StackPanel>
    </Grid>
</Window>
