<Window x:Class="MedHelp.Views.CallDoctorHomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вызов врача на дом" Height="650" Width="650"
        MinHeight="500" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,25">
            <TextBlock Text="🚑 Вызов врача на дом" FontSize="24" FontWeight="Bold" Foreground="#D32F2F"/>
            <TextBlock Text="Заполните форму для отправки заявки" FontSize="13" Foreground="#777777" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Адрес:" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
            <ComboBox x:Name="cmbAddress" Grid.Column="1" IsEditable="True" FontSize="14" Padding="5" VerticalContentAlignment="Center" ToolTip="Введите или выберите адрес">
                <ComboBox.Style>
                    <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBox">
                                    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4" Background="White">
                                        <Grid>
                                            <TextBox x:Name="PART_EditableTextBox" Margin="0" Padding="5" VerticalContentAlignment="Center" FontSize="14" BorderThickness="0"/>
                                            <ToggleButton HorizontalAlignment="Right" Width="20" Margin="0,0,2,0" Focusable="False" ClickMode="Press"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ComboBox.Style>
            </ComboBox>
        </Grid>
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Телефон:" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
            <TextBox x:Name="txtPhone" Grid.Column="1" FontSize="14" Padding="5" VerticalContentAlignment="Center" BorderBrush="#CCCCCC" BorderThickness="1" ToolTip="Пример: +375 (29) 123-45-67"/>
        </Grid>
        <Grid Grid.Row="3" Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Жалобы:" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                <TextBox x:Name="txtComplaints"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="14"
                         Padding="8"
                         MinHeight="100"
                         VerticalAlignment="Stretch"
                         ToolTip="Опишите симптомы"/>
            </Border>
        </Grid>
        <TextBlock Grid.Row="4" Text="⚠️ Врач свяжется с вами по указанному телефону для уточнения деталей."
                   FontSize="12" Foreground="#FF9800" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="btnSubmitCall" Content="🚑 Отправить заявку" Click="BtnSubmitCall_Click" MinWidth="160" Height="40" Margin="0,0,15,0" FontSize="14" Cursor="Hand" IsDefault="True" ToolTip="Отправить (Enter)"/>
            <Button x:Name="btnCancelCall" Content="Отмена" Click="BtnCancelCall_Click" MinWidth="120" Height="40" FontSize="14" Cursor="Hand" IsCancel="True" ToolTip="Отмена (Esc)"/>
        </StackPanel>
    </Grid>
</Window>