<Window x:Class="MedHelp.Views.DoctorDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Информация о враче" Height="550" Width="600"
        MinHeight="450" MinWidth="500"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Информация о враче" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="ФИО:" FontWeight="SemiBold" Padding="0"/>
                    <TextBlock x:Name="lblFullName" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Специальность:" FontWeight="SemiBold" Padding="0"/>
                    <TextBlock x:Name="lblSpecialty" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Кабинет:" FontWeight="SemiBold" Padding="0"/>
                    <TextBlock x:Name="lblCabinet" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Стаж:" FontWeight="SemiBold" Padding="0"/>
                    <TextBlock x:Name="lblExperience" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Row="5" Margin="0,0,0,20">
            <Border BorderBrush="Gray" BorderThickness="1" Padding="8" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Образование:" FontWeight="SemiBold" Padding="0" VerticalAlignment="Top"/>
                    <TextBlock x:Name="lblEducation" Grid.Column="1" VerticalAlignment="Top" Margin="10,5,0,0" TextWrapping="Wrap"/>
                </Grid>
            </Border>
        </Grid>
        <Button Grid.Row="7" Content="Закрыть" Width="100" Height="35" HorizontalAlignment="Center" Click="BtnClose_Click" FontSize="14" IsCancel="True" ToolTip="Закрыть (Esc)"/>
    </Grid>
</Window>