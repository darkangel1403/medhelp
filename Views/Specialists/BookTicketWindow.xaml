<Window x:Class="MedHelp.Views.BookTicketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Заказ талона"
        Height="650" Width="750"
        MinHeight="500" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        ResizeMode="CanResizeWithGrip">
    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding ConfirmCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    </Window.InputBindings>
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="📅 Заказ талона на приём" FontSize="24" FontWeight="Bold" Foreground="#007ACC"/>
            <TextBlock x:Name="lblDoctorName" Text="" FontSize="16" Foreground="#555555" HorizontalAlignment="Center" Margin="0,5,0,0" FontStyle="Italic"/>
        </StackPanel>
        <Border Grid.Row="1" Background="#F9F9F9" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Выберите дату:" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Margin="0,0,15,0"/>
                <DatePicker x:Name="dpDate" Grid.Column="1" SelectedDate="{x:Static sys:DateTime.Today}" FontSize="14" Padding="5" ToolTip="Выберите дату приема"/>
            </Grid>
        </Border>
        <GroupBox Grid.Row="2" Header="Свободные талоны" Padding="10" Margin="0,20,0,0" FontSize="14" FontWeight="SemiBold">
            <DataGrid x:Name="dgFreeTickets"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionChanged="DgFreeTickets_SelectionChanged"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      RowHeight="35"
                      Background="White"
                      AlternatingRowBackground="#F5FAFF"
                      CanUserAddRows="False"
                      ScrollViewer.CanContentScroll="True"
                      CanUserSortColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Время начала приёма" Binding="{Binding VisitDate, StringFormat='dd.MM.yyyy (HH:mm)'}" Width="*"/>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#007ACC"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </GroupBox>
        <TextBlock Grid.Row="3"
                   Text="💡 Выберите время из списка выше, чтобы активировать кнопку подтверждения."
                   FontSize="12"
                   Foreground="#999999"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"
                   TextWrapping="Wrap"/>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="btnConfirmBooking"
                    Content="✅ Подтвердить запись"
                    Click="BtnConfirmBooking_Click"
                    MinWidth="170"
                    Height="40"
                    Margin="0,0,15,0"
                    FontSize="14"
                    Cursor="Hand"
                    IsEnabled="False"
                    Background="#E3F2FD"
                    BorderBrush="#90CAF9"
                    Foreground="#1565C0"
                    IsDefault="True"
                    ToolTip="Подтвердить запись (Enter)"/>
            <Button x:Name="btnCancelBooking"
                    Content="Отмена"
                    Click="BtnCancelBooking_Click"
                    MinWidth="120"
                    Height="40"
                    FontSize="14"
                    Cursor="Hand"
                    Background="#F5F5F5"
                    BorderBrush="#CCCCCC"
                    Foreground="#333333"
                    IsCancel="True"
                    ToolTip="Отмена (Esc)"/>
        </StackPanel>
    </Grid>
</Window>
