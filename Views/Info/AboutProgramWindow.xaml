<Window x:Class="MedHelp.Views.AboutProgramWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="О программе" Height="500" Width="650"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterScreen" 
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,15">
            <TextBlock Text="🏥 MedHelp" FontSize="32" FontWeight="Bold" Foreground="#007ACC" HorizontalAlignment="Center"/>
            <TextBlock Text="Система учёта пациентов поликлиники" FontSize="16" Foreground="#555555" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>
        <Border Grid.Row="1" Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Версия: 1.0" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="Год выпуска: 2026" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="200">
            <TextBlock TextWrapping="Wrap" LineHeight="20" FontSize="13" Foreground="#333333">
                <Run FontWeight="Bold">Назначение:</Run><LineBreak/>
                Программный продукт предназначен для автоматизации работы регистратуры городской поликлиники.<LineBreak/><LineBreak/>
                <Run FontWeight="Bold">Основные возможности:</Run><LineBreak/>
                • Электронная запись к врачу.<LineBreak/>
                • Вызов врача на дом.<LineBreak/>
                • Личный кабинет пациента.<LineBreak/>
                • Экспорт данных (Excel, CSV, JSON).<LineBreak/>
                • Печать талонов.<LineBreak/><LineBreak/>
                <Run FontWeight="Bold">Технологии:</Run><LineBreak/>
                C#, .NET, WPF, MS SQL Server.
            </TextBlock>
        </ScrollViewer>
        <Button Grid.Row="3" Content="ОК" Width="120" Height="35" HorizontalAlignment="Center" Click="BtnOk_Click" Margin="0,20,0,0" Cursor="Hand" IsCancel="True" ToolTip="Закрыть (Esc)"/>
    </Grid>
</Window>