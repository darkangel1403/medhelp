<Window x:Class="MedHelp.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Справка" Height="550" Width="700"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Справка по использованию системы MedHelp" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <TextBlock Name="helpContentTextBlock" TextWrapping="Wrap" Padding="10" FontSize="14" LineHeight="22">
                <Run FontWeight="Bold">1. ВХОД И РЕГИСТРАЦИЯ</Run><LineBreak/>
                Используйте кнопку «Регистрация» для создания аккаунта. Для входа введите логин и пароль.<LineBreak/><LineBreak/>
                <Run FontWeight="Bold">2. ЗАПИСЬ К ВРАЧУ</Run><LineBreak/>
                Выберите раздел «Специалисты», найдите нужного врача и нажмите «Заказать талон».<LineBreak/><LineBreak/>
                <Run FontWeight="Bold">3. ВЫЗОВ НА ДОМ</Run><LineBreak/>
                Заполните форму вызова, указав адрес и жалобы.<LineBreak/><LineBreak/>
                <Run FontWeight="Bold">4. ЛИЧНЫЙ КАБИНЕТ</Run><LineBreak/>
                Просмотр истории, отмена записей, экспорт данных в файлы.<LineBreak/><LineBreak/>
                <Run FontWeight="Bold">5. АДМИНИСТРАТОР</Run><LineBreak/>
                Управление справочниками врачей и пациентов, генерация расписания.
            </TextBlock>
        </ScrollViewer>
        <Button Grid.Row="2" Content="Закрыть" Width="100" Height="35" HorizontalAlignment="Center" Margin="0,20,0,0" Click="BtnClose_Click" IsCancel="True" ToolTip="Закрыть (Esc)"/>
    </Grid>
</Window>