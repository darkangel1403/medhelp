<Window x:Class="MedHelp.Views.AboutDeveloperWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="О разработчике" Height="450" Width="600"
        MinHeight="350" MinWidth="450"
        WindowStartupLocation="CenterScreen" 
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Разработчик" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
        <StackPanel Grid.Row="1" HorizontalAlignment="Center">
            <TextBlock Text="Латышев Ярослав Юрьевич" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="Группа: 82ТП" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,5" Foreground="Gray"/>
            <TextBlock Text="Минский государственный колледж цифровых технологий" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,15"/>
        </StackPanel>
        <TextBlock Grid.Row="2" Text="Курсовой проект по дисциплине:" HorizontalAlignment="Center" Margin="0,0,0,5"/>
        <TextBlock Grid.Row="3" Text="«Конструирование программ и языки программирования»" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Top" FontStyle="Italic"/>
        <Button Grid.Row="4" Content="ОК" Width="100" Height="35" HorizontalAlignment="Center" Click="BtnOk_Click" Margin="0,20,0,0" IsCancel="True" ToolTip="Закрыть (Esc)"/>
    </Grid>
</Window>
