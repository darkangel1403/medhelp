<Window x:Class="MedHelp.Views.MainMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MedHelp — Регистратура" 
        Height="500" Width="450"
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,40">
            <TextBlock Text="🏥 MedHelp" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Foreground="#2196F3"/>
            <TextBlock Text="Система учёта пациентов" 
                       FontSize="14" 
                       HorizontalAlignment="Center" 
                       Foreground="Gray" 
                       Margin="0,5,0,0"/>
        </StackPanel>
        
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Stretch">
            <Button x:Name="btnRegister" 
                    Content="📝 Регистрация нового пользователя" 
                    Width="280" 
                    Height="45" 
                    Margin="0,0,0,15" 
                    Click="BtnRegister_Click" 
                    FontSize="14"
                    Cursor="Hand"
                    Background="#E3F2FD"
                    BorderBrush="#90CAF9"
                    Foreground="#1565C0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="1" 
                                            CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#BBDEFB"/>
                                <Setter Property="BorderBrush" Value="#64B5F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#90CAF9"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button x:Name="btnLogin" 
                    Content="🚪 Войти в систему" 
                    Width="280" 
                    Height="45" 
                    Margin="0,0,0,15" 
                    Click="BtnLogin_Click" 
                    FontSize="14"
                    Cursor="Hand"
                    Background="#E8F5E9"
                    BorderBrush="#A5D6A7"
                    Foreground="#2E7D32">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="1" 
                                            CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C8E6C9"/>
                                <Setter Property="BorderBrush" Value="#81C784"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#A5D6A7"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button x:Name="btnExit" 
                    Content="❌ Выход из приложения" 
                    Width="280" 
                    Height="45" 
                    Margin="0,0,0,15" 
                    Click="BtnExit_Click" 
                    FontSize="14"
                    Cursor="Hand"
                    Background="#FFEBEE"
                    BorderBrush="#EF9A9A"
                    Foreground="#C62828">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="1" 
                                            CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFCDD2"/>
                                <Setter Property="BorderBrush" Value="#EF5350"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#EF9A9A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <TextBlock Grid.Row="2" 
                   Text="Версия 1.0 © 2026" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Bottom" 
                   Foreground="LightGray" 
                   FontSize="12"
                   Margin="0,0,0,10" Cursor="Hand"/>
    </Grid>
</Window>
