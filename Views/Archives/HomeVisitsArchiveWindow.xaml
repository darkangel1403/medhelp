<Window x:Class="MedHelp.Views.HomeVisitsArchiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Архив вызовов" Height="600" Width="800"
        WindowStartupLocation="CenterOwner" FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="История вызовов" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
        <DataGrid Grid.Row="1" x:Name="dgArchive" AutoGenerateColumns="False" IsReadOnly="True" 
                  GridLinesVisibility="All" BorderBrush="Gray" RowHeight="30" FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Врач" Binding="{Binding DoctorName}" Width="*"/>
                <DataGridTextColumn Header="Дата заявки" Binding="{Binding RequestDate, StringFormat='dd.MM.yyyy HH:mm'}" Width="*"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="Red"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Жалобы" Binding="{Binding Complaints}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="📄 Экспорт" Width="120" Height="35" Margin="0,0,10,0" Click="BtnExport_Click" FontSize="13" Cursor="Hand"/>
            <Button Content="📧 Отправить на почту" Width="150" Height="35" Margin="0,0,10,0" Click="BtnSendEmail_Click" FontSize="13" Cursor="Hand"/>
            <Button Content="Закрыть" Width="100" Height="35" Margin="0" Click="BtnClose_Click" FontSize="13" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
