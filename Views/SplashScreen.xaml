<Window x:Class="MedHelp.Views.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MedHelp — Загрузка"
        Height="450" Width="550"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="Transparent">
    <Window.Resources>
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="LogoScaleTransform" Storyboard.TargetProperty="ScaleX" From="1.0" To="1.05" Duration="0:0:1.5" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="LogoScaleTransform" Storyboard.TargetProperty="ScaleY" From="1.0" To="1.05" Duration="0:0:1.5" AutoReverse="True"/>
        </Storyboard>
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.8"/>
            <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="20" To="0" Duration="0:0:0.8"/>
        </Storyboard>
    </Window.Resources>
    <Grid>
        <Border x:Name="MainBorder" Background="#FFFFFF" CornerRadius="20" BorderThickness="0">
            <Border.Effect>
                <DropShadowEffect Color="#007ACC" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
            </Border.Effect>
            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,30,0,20">
                    <TextBlock Text="🏥" FontSize="48" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <ScaleTransform x:Name="LogoScaleTransform"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <TextBlock Text="MedHelp" FontSize="42" FontWeight="Bold" Foreground="#007ACC" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    <TextBlock Text="Система учёта пациентов" FontSize="16" Foreground="#777777" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
                <Grid Grid.Row="2" Margin="0,20,0,10">
                    <Border Background="#F0F0F0" CornerRadius="6" Height="12">
                        <Border.Clip>
                            <RectangleGeometry Rect="0,0,490,12" RadiusX="6" RadiusY="6"/>
                        </Border.Clip>
                        <ProgressBar x:Name="progressBar" Minimum="0" Maximum="100" Value="0" BorderThickness="0" Foreground="#00BFFF" Background="Transparent"/>
                    </Border>
                </Grid>
                <TextBlock Grid.Row="3" x:Name="statusText" Text="Инициализация..." FontSize="13" Foreground="#555555" HorizontalAlignment="Left" Margin="5,5,0,0"/>
                <TextBlock Grid.Row="4" x:Name="tipsText" Text="" FontSize="12" Foreground="#999999" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,10,0,10" TextWrapping="Wrap" MaxWidth="400"/>
                <TextBlock Grid.Row="5" Text="Версия 1.0 © 2026" FontSize="11" Foreground="#CCCCCC" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,10,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>